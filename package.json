{
  "name": "@peter.naydenov/route-emitter",
  "description": "Changes in URL are converted in events according routes definition list",
  "version": "2.2.16",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "src/main.js",
  "type": "module",
  "types": "types/main.d.ts",
  "exports": {
    ".": {
      "import": "./src/main.js",
      "require": "./dist/route-emitter.cjs",
      "default": "./src/main.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "cover": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/route-emitter.git"
  },
  "dependencies": {
    "@peter.naydenov/notice": "^2.4.5",
    "@peter.naydenov/url-pattern": "^1.0.6",
    "ask-for-promise": "^3.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "micro",
    "frontend",
    "MFE",
    "router",
    "emitter"
  ],
  "allowScripts": {
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
